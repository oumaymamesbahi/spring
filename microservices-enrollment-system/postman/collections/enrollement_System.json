                    }
                },
                {
                    "name": "4.3 Verify deletion - Dashboard should show 0 courses",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test(\"Status code is 200\", function() {",
                                    "    pm.response.to.have.status(200);",
                                    "});",
                                    "var jsonData = pm.response.json();",
                                    "pm.test(\"Enrollment was deleted\", function() {",
                                    "    var found = jsonData.some(e => e.enrollmentId == pm.variables.get('enrollment_id'));",
                                    "    pm.expect(found).to.be.false;",
                                    "});"
                                ],
                                "type": "text/javascript"
                            }
