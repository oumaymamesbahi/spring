        {
            "name": "===== PART 3: DASHBOARD - Student Enrollments =====",
            "description": "Upon entering their CNIE, the student should see a list of all courses they are currently enrolled in",
            "item": [
                {
                    "name": "3.1 Dashboard for Student 1 (Should show 1 course)",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test(\"Status code is 200\", function() {",
                                    "    pm.response.to.have.status(200);",
                                    "});",
                                    "var jsonData = pm.response.json();",
                                    "pm.test(\"Dashboard returns array\", function() {",
                                    "    pm.expect(jsonData).to.be.an('array');",
                                    "});",
                                    "pm.test(\"Student has at least 1 enrollment\", function() {",
                                    "    pm.expect(jsonData.length).to.be.at.least(1);",
                                    "});",
                                    "pm.test(\"Course name is displayed\", function() {",
                                    "    if(jsonData.length > 0) {",
                                    "        pm.expect(jsonData[0]).to.have.property('courseName');",
                                    "    }",
                                    "});"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{base_url}}/api/enrollments/student/{{student1_cnie}}",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "enrollments",
                                "student",
                                "{{student1_cnie}}"
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "===== PART 4: RULE - 24-Hour Cancellation =====",
            "description": "Students can delete/cancel an enrollment only if it was created less than 24 hours ago",
            "item": [
                {
                    "name": "4.1 Check deletable flag is TRUE (recent enrollment)",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test(\"Status code is 200\", function() {",
                                    "    pm.response.to.have.status(200);",
                                    "});",
                                    "var jsonData = pm.response.json();",
                                    "pm.test(\"deletable flag is true\", function() {",
                                    "    if(jsonData.length > 0) {",
                                    "        pm.expect(jsonData[0].deletable).to.be.true;",
                                    "    }",
                                    "});"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "GET",
                        "url": {
